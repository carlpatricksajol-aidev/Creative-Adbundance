{
  "trailingSlash": false,
  "redirects": [
    { "source": "/index.html",     "destination": "/",          "permanent": true },
    { "source": "/create.html",    "destination": "/create",    "permanent": true },
    { "source": "/checkout.html",  "destination": "/checkout",  "permanent": true },
    { "source": "/templates.html", "destination": "/templates", "permanent": true },
    { "source": "/contact.html",   "destination": "/contact",   "permanent": true },
    { "source": "/privacy.html",   "destination": "/privacy",   "permanent": true },
    { "source": "/terms.html",     "destination": "/terms",     "permanent": true }
  ],
  "rewrites": [
    { "source": "/",          "destination": "/Songreels/index.html" },
    { "source": "/app",       "destination": "/Songreels/create.html" },
    { "source": "/create",    "destination": "/Songreels/create.html" },
    { "source": "/checkout",  "destination": "/Songreels/checkout.html" },
    { "source": "/templates", "destination": "/Songreels/templates.html" },
    { "source": "/contact",   "destination": "/Songreels/contact.html" },
    { "source": "/privacy",   "destination": "/Songreels/privacy.html" },
    { "source": "/terms",     "destination": "/Songreels/terms.html" },
    { "source": "/(.*)",      "destination": "/Songreels/$1" }
  ]
}
